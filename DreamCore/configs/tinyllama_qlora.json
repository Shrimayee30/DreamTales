{
  "model_name": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
  "dataset_name": "roneneldan/TinyStories",
  "dataset_text_field": "text",
  "prompt_mode": "synthetic_instruction",
  "output_dir": "DreamCore/outputs/tinyllama-tinystories",
  "max_seq_length": 512,
  "max_train_samples": 50000,
  "max_eval_samples": 2000,
  "num_train_epochs": 2.0,
  "max_steps": -1,
  "learning_rate": 0.0002,
  "weight_decay": 0.01,
  "warmup_steps": 94,
  "lr_scheduler_type": "cosine",
  "per_device_train_batch_size": 4,
  "per_device_eval_batch_size": 4,
  "gradient_accumulation_steps": 8,
  "logging_steps": 10,
  "save_steps": 250,
  "eval_steps": 250,
  "save_total_limit": 2,
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "gradient_checkpointing": true,
  "use_bf16": false,
  "use_4bit": false,
  "seed": 42
}
