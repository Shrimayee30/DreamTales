{
  "model_name": "TinyLlama/TinyLlama-1.1B-Chat-v1.0",
  "dataset_name": "roneneldan/TinyStories",
  "dataset_text_field": "text",
  "prompt_mode": "synthetic_instruction",
  "output_dir": "DreamCore/outputs/tinyllama-smoke",
  "max_seq_length": 256,
  "max_train_samples": 128,
  "max_eval_samples": 64,
  "num_train_epochs": 1.0,
  "max_steps": 5,
  "learning_rate": 0.0002,
  "weight_decay": 0.01,
  "warmup_ratio": 0.03,
  "lr_scheduler_type": "cosine",
  "per_device_train_batch_size": 1,
  "per_device_eval_batch_size": 1,
  "gradient_accumulation_steps": 2,
  "logging_steps": 1,
  "save_steps": 5,
  "eval_steps": 5,
  "save_total_limit": 1,
  "lora_r": 8,
  "lora_alpha": 16,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "gradient_checkpointing": true,
  "use_bf16": false,
  "use_4bit": false,
  "seed": 42,
  "trust_remote_code": false
}